<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:custom="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:theme="@style/PaymentButtonsTheme"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Venmo toggle column -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:text="@string/venmo" />

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/venmo_button_toggle_group"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    custom:checkedButton="@id/button_venmo_blue"
                    custom:singleSelection="true">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_venmo_blue"
                        style="@style/ColorToggleButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/blue_button_color_option"
                        custom:backgroundTint="@color/toggle_stroke_color" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_venmo_black"
                        style="@style/ColorToggleButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/black_button_color_option"
                        custom:backgroundTint="@color/toggle_stroke_color" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_venmo_white"
                        style="@style/ColorToggleButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/white_button_color_option"
                        custom:backgroundTint="@color/toggle_stroke_color" />
                </com.google.android.material.button.MaterialButtonToggleGroup>
            </LinearLayout>

            <!-- PayPal toggle column -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:text="@string/paypal" />

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/pp_button_toggle_group"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    custom:checkedButton="@id/button_pp_blue"
                    custom:singleSelection="true">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_pp_blue"
                        style="@style/ColorToggleButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/blue_button_color_option"
                        custom:backgroundTint="@color/toggle_stroke_color" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_pp_black"
                        style="@style/ColorToggleButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/black_button_color_option"
                        custom:backgroundTint="@color/toggle_stroke_color" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_pp_white"
                        style="@style/ColorToggleButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/white_button_color_option"
                        custom:backgroundTint="@color/toggle_stroke_color" />
                </com.google.android.material.button.MaterialButtonToggleGroup>
            </LinearLayout>
        </LinearLayout>

        <!-- ===== Card Fields section ===== -->
        <com.braintreepayments.api.uicomponents.cardfields.CardFields
            android:id="@+id/card_fields"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp" />

        <Button
            android:id="@+id/pay_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/card_fields_pay_button_background"
            android:enabled="false"
            android:gravity="center"
            android:minHeight="52dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:text="@string/card_fields_pay" />

        <!-- ===== Payment buttons section ===== -->
        <com.braintreepayments.api.uicomponents.VenmoButton
            android:id="@+id/venmo_payment_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="24dp"
            custom:buttonColor="blue" />

        <com.braintreepayments.api.uicomponents.PayPalButton
            android:id="@+id/pp_payment_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            custom:buttonColor="blue" />

    </LinearLayout>
</ScrollView>
