<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:parentTag="android.widget.LinearLayout">

    <FrameLayout
        android:id="@+id/input_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="@dimen/card_field_min_height">

        <TextView
            android:id="@+id/hint_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start|center_vertical"
            android:layout_marginStart="@dimen/card_field_padding_horizontal"
            android:labelFor="@id/text_input_edit_text"
            android:textColor="@color/card_field_hint_text"
            android:textSize="@dimen/card_field_hint_text_size" />

        <EditText
            android:id="@+id/text_input_edit_text"
            android:layout_width="match_parent"
            android:layout_height="@dimen/card_field_input_height"
            android:layout_gravity="start|bottom"
            android:layout_marginBottom="@dimen/card_field_input_margin_bottom"
            android:background="@null"
            android:inputType="text"
            android:maxLines="1"
            android:paddingStart="@dimen/card_field_padding_horizontal"
            android:paddingEnd="@dimen/card_field_padding_horizontal"
            android:textColor="@color/card_field_text"
            android:textSize="16sp" />

    </FrameLayout>

    <TextView
        android:id="@+id/error_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/card_field_error_margin_top"
        android:drawablePadding="4dp"
        app:drawableStartCompat="@drawable/ic_card_field_error"
        android:gravity="center_vertical"
        android:textColor="@color/card_field_text"
        android:textSize="12sp"
        android:visibility="gone" />

</merge>